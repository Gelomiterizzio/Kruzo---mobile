# ─────────────────────────────────────────────────────────────────────────────
# KRUZO mobile — environment template. Copy to `.env` and fill real values.
#   cp .env.example .env
#
# EXPO_PUBLIC_* are inlined into the JS bundle (public by design, like the web
# NEXT_PUBLIC_* Firebase config). Security is enforced by Firestore/Storage rules.
# These point at the SAME Firebase project as web/ (kruzo-web). Do NOT create a
# new project — the mobile app is just another client of the same backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Web SDK (public) ────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Google Sign-In (native) ──────────────────────────────────────────────────
# The Web client id from Google Cloud OAuth (used by @react-native-google-signin
# to mint an idToken that Firebase accepts via signInWithCredential).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Google Maps (Android, for react-native-maps) ──────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://kruzo.bo
